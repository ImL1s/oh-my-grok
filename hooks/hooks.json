{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${GROK_PLUGIN_ROOT}/hooks/bin/session_start.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${GROK_PLUGIN_ROOT}/hooks/bin/subagent_stop.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${GROK_PLUGIN_ROOT}/hooks/bin/stop.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "run_terminal_command|Bash|Shell",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${GROK_PLUGIN_ROOT}/hooks/bin/pre_tool_use_deny.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
